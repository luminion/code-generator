package ${serviceImpl.packageName};
#if($serviceImplFramePkg.size()>0)

#end
#foreach($pkg in ${serviceImplFramePkg})
import ${pkg};
#end
#if($serviceImplJavaPkg.size()>0)

#end
#foreach($pkg in ${serviceImplJavaPkg})
import ${pkg};
#end

/**
 * $!{table.comment}-服务实现类
 *
 * @author ${author}
#if(${date})
 * @since ${date}    
#end
 */
@Service
#if(${service.generate})
#if(${stateless})
public class ${serviceImpl.classSimpleName} implements ${service.classSimpleName} {
#else
public class ${serviceImpl.classSimpleName} extends ${serviceImplSuperClass}<${mapper.classSimpleName}, ${entity.classSimpleName}#if(${sqlBooster}), ${queryResult.classSimpleName}#end> implements ${service.classSimpleName} {
#end
#else
#if(${stateless})
public class ${serviceImpl.classSimpleName} {
#else
public class ${serviceImpl.classSimpleName} extends ${serviceImplSuperClass}<${mapper.classSimpleName}, ${entity.classSimpleName}#if(${sqlBooster}), ${queryResult.classSimpleName}#end> {
#end
#end
#if(${stateless})

    private final ${mapper.classSimpleName} baseMapper;

    public ${serviceImpl.classSimpleName}(${mapper.classSimpleName} baseMapper) {
        this.baseMapper = baseMapper;
    }
#end
#if(${generateCreate})

    #if(${service.generate})
    @Override
    #end
    #if(${table.idField})
    public ${table.idField.propertyType} ${createMethodName}(${createParam.classSimpleName} param) {
    #else
    public boolean ${createMethodName}(${createParam.classSimpleName} param) {
    #end
        ${entity.classSimpleName} entity = new ${entity.classSimpleName}();
        BeanUtils.copyProperties(param, entity);
        #if(${stateless})
        int saved = baseMapper.insert(entity);
        #else
        boolean saved = super.save(entity);
        #end
        #if(${table.idField})
        return entity.get${table.idField.capitalName}();
        #else
        #if(${stateless})
        return saved > 0;
        #else
        return saved;
        #end
        #end
    }
#end
#if(${generateUpdate} && ${table.idField})

    #if(${service.generate})
    @Override
    #end
    public boolean ${updateMethodName}(${updateParam.classSimpleName} param) {
        ${entity.classSimpleName} entity = new ${entity.classSimpleName}();
        BeanUtils.copyProperties(param, entity);
        #if(${stateless})
        return baseMapper.updateById(entity) > 0;
        #else
        return super.updateById(entity);
        #end
    }
#end
#if(${generateDelete} && ${table.idField})

    @Override
    public boolean ${deleteMethodName}(${table.idField.propertyType} id) {
        #if(${stateless})
        return baseMapper.deleteById(id) > 0;
        #else
        return super.removeById(id);
        #end
    }
#end
#if(${generateQueryById} && ${table.idField} && !${sqlBooster})

    #if(${service.generate})
    @Override
    #end
    public ${queryResult} ${queryByIdMethodName}(${table.idField.propertyType} id) {
        ${queryParam.classSimpleName} param = new ${queryParam.classSimpleName}();
        param.set${table.idField.capitalName}(id);
        #if(${stateless})
        ${queryResult} one = baseMapper.selectByXml(param, null)
        #else
        ${queryResult} one = getBaseMapper().selectByXml(param, null)
        #end
                .stream()
                .findFirst()
                .orElse(null);
        return one;
    }
#end
#if(${generateQueryList} && !${sqlBooster})

    #if(${service.generate})
    @Override
    #end
    public List<${queryResult}> ${queryListMethodName}(${queryParam.classSimpleName} dto) {
        #if(${stateless})
        List<${queryResult}> list = baseMapper.selectByXml(dto, null);
        #else
        List<${queryResult}> list = getBaseMapper().selectByXml(dto, null);
        #end
        return list;
    }
#end
#if(${generateQueryPage} && !${sqlBooster})

    #if(${service.generate})
    @Override
    #end
    public ${servicePageType}<${queryResult}> ${queryPageMethodName}(${queryParam.classSimpleName} param, long current, long size) {
        Page<${queryResult}> page = new Page<>(current, size);
        #if(${stateless})
        List<${queryResult}> list = baseMapper.selectByXml(param, page);
        #else
        List<${queryResult}> list = getBaseMapper().selectByXml(param, page);
        #end
        page.setRecords(list);
        return page;
    }
#end
#if(${generateExcelImport})

    #if(${service.generate})
    @Override
    #end
    public void ${excelImportTemplateMethodName}(OutputStream os) {
        ${excelApiClass}.write(os, ${excelImportParam.classSimpleName}.class)
            .sheet()
            .registerWriteHandler(new LongestMatchColumnWidthStyleStrategy())
            .doWrite(Collections.emptyList());
    }

    #if(${service.generate})
    @Override
    #end
    public int ${excelImportMethodName}(InputStream is) {
        #if(${excelImportBatchMode})
        AtomicInteger importCount = new AtomicInteger();
        List<${entity.classSimpleName}> entityList = new ArrayList<>(${excelImportBatchSize});
        ${excelApiClass}.read(is, ${excelImportParam.classSimpleName}.class, new AnalysisEventListener<${excelImportParam.classSimpleName}>() {
            @Override
            public void invoke(${excelImportParam.classSimpleName} importDto, AnalysisContext context) {
                ${entity.classSimpleName} entity = new ${entity.classSimpleName}();
                BeanUtils.copyProperties(importDto, entity);
                entityList.add(entity);
                if (entityList.size() >= ${excelImportBatchSize}) {
                    importCount.addAndGet(flushExcelImportBatch(entityList));
                }
            }

            @Override
            public void doAfterAllAnalysed(AnalysisContext context) {
                importCount.addAndGet(flushExcelImportBatch(entityList));
            }
        }).sheet().doRead();
        return importCount.get();
        #else
        List<${excelImportParam.classSimpleName}> dataList = ${excelApiClass}.read(is)
            .head(${excelImportParam.classSimpleName}.class).sheet().doReadSync();
        List<${entity.classSimpleName}> entityList = dataList.stream().map(importDto -> {
            ${entity.classSimpleName} entity = new ${entity.classSimpleName}();
            BeanUtils.copyProperties(importDto, entity);
            return entity;
        }).collect(Collectors.toList());
        #if(${stateless})
        for (${entity.classSimpleName} entity : entityList) {
            baseMapper.insert(entity);
        }
        #else
        super.saveBatch(entityList);
        #end
        return entityList.size();
        #end
    }

    #if(${excelImportBatchMode})
    private int flushExcelImportBatch(List<${entity.classSimpleName}> entityList) {
        if (entityList.isEmpty()) {
            return 0;
        }
        #if(${stateless})
        for (${entity.classSimpleName} entity : entityList) {
            baseMapper.insert(entity);
        }
        #else
        super.saveBatch(entityList);
        #end
        int savedCount = entityList.size();
        entityList.clear();
        return savedCount;
    }
    #end
#end
#if(${generateExcelExport})

    #if(${service.generate})
    @Override
    #end
    public void ${excelExportMethodName}(${queryParam.classSimpleName} param, OutputStream os) {
        #if(${excelExportPagedMode})
        try (ExcelWriter excelWriter = ${excelApiClass}.write(os, ${excelExportParam.classSimpleName}.class).build()) {
            WriteSheet writeSheet = ${excelApiClass}.writerSheet()
                    .registerWriteHandler(new LongestMatchColumnWidthStyleStrategy())
                    .build();
            long current = 1L;
            while (true) {
                List<${queryResult}> records = queryExcelExportPage(param, current, ${excelExportPageSize}L);
                if (records == null || records.isEmpty()) {
                    break;
                }
                excelWriter.write(records, writeSheet);
                if (records.size() < ${excelExportPageSize}) {
                    break;
                }
                current++;
            }
        }
        #else
        #if(${sqlBooster})
        List<${queryResult}> records = ${sqlBoosterLambdaMethodName}().${sqlBoosterFromBeanMethodName}(param).list();
        #else
        #if(${stateless})
        List<${queryResult}> records = baseMapper.selectByXml(param, null);
        #else
        List<${queryResult}> records = getBaseMapper().selectByXml(param, null);
        #end
        #end
        ${excelApiClass}.write(os, ${excelExportParam.classSimpleName}.class)
                .sheet()
                .registerWriteHandler(new LongestMatchColumnWidthStyleStrategy())
                .doWrite(records);
        #end
    }

    #if(${excelExportPagedMode})
    private List<${queryResult}> queryExcelExportPage(${queryParam.classSimpleName} param, long current, long size) {
        #if(${sqlBooster})
        return ${sqlBoosterLambdaMethodName}().${sqlBoosterFromBeanMethodName}(param).page(current, size).getRecords();
        #else
        Page<${queryResult}> page = new Page<>(current, size);
        #if(${stateless})
        return baseMapper.selectByXml(param, page);
        #else
        return getBaseMapper().selectByXml(param, page);
        #end
        #end
    }
    #end
#end
}
