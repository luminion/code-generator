package ${package.service};
#if($serviceFrameworkPkg.size()>0)

#end
#foreach($pkg in ${serviceFrameworkPkg})
import ${pkg};
#end
#if($serviceJavaPkg.size()>0)

#end
#foreach($pkg in ${serviceJavaPkg})
import ${pkg};
#end

/**
 * $!{table.comment} 服务类
 *
 * @author ${docAuthor}
 * @since ${docDate}
 */
public interface ${service} extends ${serviceSuperClass}<${entity}, ${queryVO}> {
#if(${enableCreateByDto})

    Serializable createByDto(${createDto} createDto);
#end
#if(${enableUpdateByDto})

    boolean updateByDto(${updateDto} updateDto);
#end
#if(${enableDeleteById} && ${table.havePrimaryKey})

    @Override
    boolean removeById(Serializable id);
#end
#if(${enableSelectVoById} && ${table.havePrimaryKey})

    @Override
    ${queryVO} voById(Serializable id);
#end
#if(${enableSelectVoList})
        
    @Override
    List<${queryVO}> voList(SqlContext<${entity}> sqlContext);
#end
#if(${enableSelectVoPage})

    @Override
    BPage<${queryVO}> voPage(SqlContext<${entity}> sqlContext, long current, long size);
#end
#if(${enableExcelImport})

    void excelTemplate(OutputStream os);

    int excelImport(InputStream is);
#end
#if(${enableExcelExport})

    void excelExport(SqlContext<${entity}> sqlContext, OutputStream os);
#end
}

