package ${controller.packageName};
#if($controllerFramePkg.size()>0)

#end
#foreach($pkg in ${controllerFramePkg})
import ${pkg};
#end
#if($controllerJavaPkg.size()>0)

#end
#foreach($pkg in ${controllerJavaPkg})
import ${pkg};
#end

/**
 * $!{table.comment}-前端控制器
 *
 * @author ${docAuthor}
#if(${docLink})
 * @see ${entity.classCanonicalName}
 * @see ${mapper.classCanonicalName}
 * @see ${serviceImpl.classCanonicalName}
#end
#if(${docDate})
 * @since ${docDate}    
#end
 */
#if(${springDoc})
@Tag(name= "$!{table.comment}-前端控制器", description = "$!{table.comment}-前端控制器")
#elseif(${swagger})
@Api(tags = "$!{table.comment}")
#end
#if(${crossOrigin})
@CrossOrigin
#end
#if(${restController})
@RestController
#else
@Controller
#end
@RequestMapping("$!{requestBaseUrl}")
#if(${lombok})
@RequiredArgsConstructor
#end
#if(${controllerSuperClass})
public class ${controller.classSimpleName} extends ${controllerSuperClass} {
#else
public class ${controller.classSimpleName} {
#end

    private final ${baseService} baseService;
#if(!${lombok})

    public ${controller.classSimpleName}(${baseService} baseService) {
        this.baseService = baseService;
    }
#end
#if(${generateCreate})

    #if(${springDoc})
    @Operation(summary = "新增")
    #elseif(${swagger})
    @ApiOperation(value = "新增")
    #else
    /**
     * 新增
     *
     * @param dto 新增入参对象
     * @return 新增后的数据id
     */
    #end
    #if(${restful})
    @PostMapping("")
    #else
    @PostMapping("/create")
    #end
    #if(!${restController})
    @ResponseBody
    #end
    public ${returnType.toTypeString("Serializable")} create($!{requiredBodyStr}$!{validStr}${createParam.classSimpleName} dto) {
        return ${returnType.toInvokeString("baseService.${createMethodName}(dto)")};
    }
#end
#if(${generateUpdate})

    #if(${springDoc})
    @Operation(summary = "修改")
    #elseif(${swagger})
    @ApiOperation(value = "修改")
    #else
    /**
     * 修改
     *
     * @param dto 修改入参对象
     * @return 是否成功
     */
    #end
    #if(${restful})
    @PutMapping("")
    #else
    @PostMapping("/update")
    #end
    #if(!${restController})
    @ResponseBody
    #end
    public ${returnType.toTypeString("Boolean")} update($!{requiredBodyStr}$!{validStr}${updateParam.classSimpleName} dto) {
        return ${returnType.toInvokeString("baseService.${updateMethodName}(dto)")};
    }
#end
#if(${generateDelete} && ${table.idField})

    #if(${springDoc})
    @Operation(summary = "删除")
    #elseif(${swagger})
    @ApiOperation(value = "删除")
    #else
    /**
     * 根据id删除
     *
     * @param id 主键id
     * @return 是否成功
     */
    #end
    #if(${restful})
    @DeleteMapping("$!{idPathParam}")
    #else
    @PostMapping("/delete$!{idPathParam}")
    #end
    #if(!${restController})
    @ResponseBody
    #end
    public ${returnType.toTypeString("Boolean")} delete($!{idMethodParam}${primaryKeyPropertyType} id) {
        return ${returnType.toInvokeString("baseService.removeById(id)")};
    }
#end
#if(${generateQueryById} && ${table.idField})

    #if(${springDoc})
    @Operation(summary = "根据id查询详情")
    #elseif(${swagger})
    @ApiOperation(value = "根据id查询详情")
    #else
    /**
     * 根据id查询详情
     *
     * @param id 主键id
     * @return 查询结果
     */
    #end
    #if(${restful})
    @GetMapping("$!{idPathParam}")
    #else
    @GetMapping("/detail$!{idPathParam}")
    #end
    #if(!${restController})
    @ResponseBody
    #end
    public ${returnType.toTypeString("${queryResult.classSimpleName}")} voById($!{idMethodParam}${primaryKeyPropertyType} id) {
        return ${returnType.toInvokeString("baseService.voById(id)")};
    }
#end
#if(${generateQueryList})

    #if(${springDoc})
    @Operation(summary = "列表查询")
    #elseif(${swagger})
    @ApiOperation(value = "列表查询")
    #else
    /**
     * 列表查询
     *
     * @param dto 查询条件
     * @return 查询结果
     */
    #end
    ${queryRequestMapping}("/list")
    #if(!${restController})
    @ResponseBody
    #end
    public ${returnType.toTypeString("List<${queryResult.classSimpleName}>")} list($!{queryBodyStr}${queryParam.classSimpleName} dto) {
        #if($sqlBooster)
        return ${returnType.toInvokeString("baseService..appendByBean(dto).list()")};    
        #else
        return ${returnType.toInvokeString("baseService.voList(dto)")};
        #end
    }
#end
#if(${generateQueryPage})

    #if(${springDoc})
    @Operation(summary = "分页查询")
    #elseif(${swagger})
    @ApiOperation(value = "分页查询")
    #else
    /**
     * 分页查询
     *
     * @param dto 查询条件
     * @param current 页码
     * @param size 每页大小
     * @return 查询结果
     */
    #end
    ${queryRequestMapping}("/page")
    #if(!${restController})
    @ResponseBody
    #end
    public ${returnType.toTypeString(${pageType.toTypeString(${queryResult.classSimpleName})})} page($!{queryBodyStr}${queryParam.classSimpleName} dto$!{pageMethodParams}) {
        #if(${queryParamSuperClass})
        Long current = dto.${pageGetter};
        Long size = dto.${sizeGetter};
        #end
        Long 
        #if($sqlBooster)
        return ${returnType.toInvokeString(${pageType.toInvokeString("baseService.lambdaBooster().appendByBean(dto).page(cuurent, size))")})};
        #else
        return ${returnType.toInvokeString(${pageType.toInvokeString("baseService.voPage(dto, current, size)")})};
        #end
    }
#end
#if(${enableExcelImport})

    #if(${springDoc})
    @Operation(summary = "下载excel导入模板")
    #elseif(${swagger})
    @ApiOperation(value = "下载excel导入模板")
    #else
    /**
     * 下载excel导入模板
     */
    #end
    @GetMapping("/excel/template")
    public void excelTemplate(HttpServletResponse response) throws IOException {
        response.setContentType("application/vnd.ms-excel");
##        response.setHeader("Access-Control-Expose-Headers", "Content-Disposition");
        response.setHeader("Content-Disposition", "attachment;filename=" + System.currentTimeMillis() + ".xlsx");
        baseService.excelTemplate(response.getOutputStream());
    }

    #if(${springDoc})
    @Operation(summary = "excel文件导入")
    #elseif(${swagger})
    @ApiOperation(value = "excel文件导入")
    #else
    /**
     * excel文件导入
     *
     * @param excel excel文件
     * @return 导入条数
     */
    #end
    @PostMapping("/excel/import")
    #if(!${restController})
    @ResponseBody
    #end
    public ${returnType.toTypeString("Integer")} excelImport(@RequestParam("excel") MultipartFile excel) throws IOException {
        if (excel == null || excel.isEmpty()) return ${returnType.toInvokeString(0)};
        return ${returnType.toInvokeString("baseService.excelImport(excel.getInputStream())")};
    }
#end
#if(${enableExcelExport})

    #if(${springDoc})
    @Operation(summary = "excel文件导出")
    #elseif(${swagger})
    @ApiOperation(value = "excel文件导出")
    #else
    /**
     * excel文件导出
     * 
     * @param dto 查询条件
     */
    #end
    ${queryRequestMapping}("/excel/export")
    public void excelExport($!{queryBodyStr}${queryParam.classSimpleName} dto, HttpServletResponse response) throws IOException {
        response.setContentType("application/vnd.ms-excel");
##        response.setHeader("Access-Control-Expose-Headers", "Content-Disposition");
        response.setHeader("Content-Disposition", "attachment;filename=" + System.currentTimeMillis() + ".xlsx");
        #if($sqlBooster)
        SqlContext<SysUser> build = SqlBuilder.of(baseService).appendEqByBean(dto).build();
        baseService.excelExport(build, response.getOutputStream());
        #else
        baseService.excelExport(dto, response.getOutputStream());
        #end
    }
#end
}