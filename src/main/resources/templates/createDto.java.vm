package ${package.createParam};
#if($createParamFramePkg.size()>0)

#end
#foreach($pkg in ${createParamFramePkg})
import ${pkg};
#end
#if($createParamJavaPkg.size()>0)

#end
#foreach($pkg in ${createParamJavaPkg})
import ${pkg};
#end

/**
 * $!{table.comment}-新增对象
 *
 * @author ${docAuthor}
#if(${docLink})
 * @see ${class.entity}
 * @see ${class.serviceImpl}
#end
#if(${docDate})
 * @since ${docDate}    
#end
 */
#if(${enableLombok})
@Getter
@Setter
#end
#if(${enableLombok} && ${enableChainSetter})
@Accessors(chain = true)
#end
#if(${enableLombok} && ${enableToString})
@ToString
#end
#if(${enableOpenApi3})
@Schema(description = "$!{table.comment}-新增对象")
#elseif(${enableOpenApi2})
@ApiModel(description = "$!{table.comment}-新增对象")
#end
public class ${createParam.classSimpleName}#if(${enableSerializableUID}) implements Serializable#end {
#if(${enableSerializableUID})

    #if(${enableSerializableAnnotation})
    @Serial
    #end
    private static final long serialVersionUID = 1L;
#end
## ----------  BEGIN 字段循环遍历  ----------
#foreach($field in ${table.fields})
#if(${field.keyFlag})
#elseif(${field.versionField})
#elseif(${field.logicDeleteField})
#elseif(${field.fill} && (${field.fill}=="INSERT" || ${field.fill}=="INSERT_UPDATE"))
#elseif(${commandExcludeColumns.contains(${field.columnName})})
#else

    #if("$!field.comment" != "")
        #if(${enableOpenApi3})
    @Schema(description = "${field.comment}")
        #elseif(${enableOpenApi2})
    @ApiModelProperty("${field.comment}")
        #else
    /**
     * ${field.comment}
     */
        #end
    #end
    #if(${enableValid})## 参数校验
        #if(!${field.metaInfo.nullable})## 非空
            #if(${field.propertyType} == "String")
    @NotBlank(message = "${field.comment}为必填项")
            #else
    @NotNull(message = "${field.comment}为必填项")
            #end
        #end
        #if(${field.propertyType} == "String")## 字符串长度
    @Size(message = "${field.comment}长度不能超过${field.metaInfo.length}", max = ${field.metaInfo.length})
        #end
    #end
    private ${field.propertyType} ${field.propertyName};
#end
#end
## ----------  END 字段循环遍历  ----------
#if(!${enableLombok})
#foreach($field in ${table.fields})
#if(${field.keyFlag})
#elseif(${field.versionField})
#elseif(${field.logicDeleteField})
#elseif(${field.fill} && (${field.fill}=="INSERT" || ${field.fill}=="INSERT_UPDATE"))
#elseif(${commandExcludeColumns.contains(${field.columnName})})
#else
    #if(${field.propertyType.equals("boolean")})
        #set($getprefix="is")
    #else
        #set($getprefix="get")
    #end

    public ${field.propertyType} ${getprefix}${field.capitalName}() {
        return ${field.propertyName};
    }

    #if(${enableChainSetter})
    public ${createParam.classSimpleName} set${field.capitalName}(${field.propertyType} ${field.propertyName}) {
    #else
    public void set${field.capitalName}(${field.propertyType} ${field.propertyName}) {
    #end
        this.${field.propertyName} = ${field.propertyName};
    #if(${enableChainSetter})
        return this;
    #end
    }
#end
#end
#end
#if(!${enableLombok} && ${enableToString})

    @Override
    public String toString() {
        return "${createParam.classSimpleName}{" +
    #foreach($field in ${table.fields})
      #if(${field.keyFlag})
      #elseif(${field.versionField})
      #elseif(${field.logicDeleteField})
      #elseif(${field.fill} && (${field.fill}=="INSERT" || ${field.fill}=="INSERT_UPDATE"))
      #elseif(${commandExcludeColumns.contains(${field.columnName})})
      #else  
            #if($!{foreach.index}==0)
        "${field.propertyName} = " + ${field.propertyName} +
            #else
        ", ${field.propertyName} = " + ${field.propertyName} +
            #end
        #end
    #end
        "}";
    }
#end
}
